rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /sessions/{sessionId} {
      allow read, write: if true;
      match /evaluations/{evalId} {
        allow read, write: if true;
      }
    }
  }
}
